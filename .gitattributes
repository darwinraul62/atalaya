# Normalización de fin de línea para que el clon funcione en cualquier equipo.
# Crítico: los .sh se ejecutan dentro de WSL y bash falla con CRLF.
* text=auto
*.sh   text eol=lf
*.mjs  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.exe  binary
